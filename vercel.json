{
  "installCommand": "cd backend && npm install && cd ../citizen-portal && npm install",
  "buildCommand": "cd citizen-portal && npm run build",
  "outputDirectory": "citizen-portal/dist",
  "functions": {
    "api/index.js": {
      "includeFiles": "backend/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/uploads/(.*)", "destination": "/api" }
  ]
}
